    "yawning": ["coda-idle.svg"],
    "dozing": ["coda-sleeping.svg"],
    "collapsing": ["coda-sleeping.svg"],
    "thinking": ["coda-thinking.svg"],
    "working": ["coda-thinking.svg"],
    "juggling": ["coda-happy.svg"],
    "sweeping": ["coda-thinking.svg"],
    "error": ["coda-error.svg"],
    "attention": ["coda-happy.svg"],
    "notification": ["coda-happy.svg"],
    "carrying": ["coda-thinking.svg"],
    "sleeping": ["coda-sleeping.svg"],
    "waking": ["coda-idle.svg"]
  }
